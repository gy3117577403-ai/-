// Prisma Schema — 治具管理系统
// 数据库：PostgreSQL
// DateTime 字段由 PostgreSQL timestamp 存储，与 Prisma @default(now()) / @updatedAt 兼容

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 枚举 ====================

/// 用户角色
enum Role {
  ADMIN      // 系统管理员
  BOSS       // 领导审批
  PURCHASER  // 采购执行
  ENGINEER   // 工程师（默认）
}

// ==================== 模型 ====================

/// 系统用户
model User {
  id        String   @id @default(cuid())
  username  String   @unique           // 登录账号，唯一
  password  String   @default("")      // 明文密码（内网 MVP）；迁移期默认空，请用种子或后台重置
  name      String   @default("未命名") // 真实姓名
  role      Role     @default(ENGINEER) // 默认工程师
  createdAt DateTime @default(now())    // 创建时间
  updatedAt DateTime @updatedAt         // 最后更新时间

  auditLogs AuditLog[] // 该用户产生的操作记录
}

/// 客户
model Customer {
  id        String    @id @default(cuid())
  code      String    @unique // 客户编码，唯一
  name      String            // 客户名称
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products Product[] // 该客户的产品列表
}

/// 产品
model Product {
  id         String    @id @default(cuid())
  code       String    @unique // 产品编码，唯一
  name       String            // 产品名称
  customerId String            // 所属客户 ID
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customer   Customer  @relation(fields: [customerId], references: [id])
  bomItems   BomItem[] // 该产品的 BOM 明细列表
  orders     Order[]   // 该产品的生产开工记录

  @@index([customerId])
}

/// 生产开工记录
model Order {
  id            String   @id @default(cuid())
  orderNo       String   @unique            // 系统自动生成的工单号
  productId     String                      // 关联产品 ID
  plannedQty    Int                         // 计划生产数量
  operator      String                      // 操作员
  status        String   @default("READY")  // READY / SHORTAGE / NO_BOM
  shortageInfo  String?                     // 缺料详情文本
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product       Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([createdAt])
}

/// BOM 明细
model BomItem {
  id             String   @id @default(cuid())
  productId      String                    // 所属产品 ID
  connectorModel String                    // 连接器型号
  quantity       Int                       // 数量
  jigModel       String?                   // 匹配的治具型号（软关联至总仓 modelCode）
  createdAt      DateTime @default(now())

  product        Product  @relation(fields: [productId], references: [id])

  @@index([productId])
}

/// 审计日志（操作记录）
model AuditLog {
  id        String   @id @default(cuid())
  action    String                      // 操作类型
  userId    String                      // 操作者 ID
  target    String                      // 操作对象描述
  oldValue  Json?                       // 变更前的值（可为空）
  newValue  Json?                       // 变更后的值（可为空）
  createdAt DateTime @default(now())    // 记录时间

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

/// 操作日志追踪
model OperationLog {
  id        String   @id @default(cuid())
  operator  String
  action    String
  module    String
  details   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// 物资分类
enum ItemCategory {
  JIG    // 生产治具
  OTHER  // 其他工具/设备
}

/// 采购申请状态
enum PurchaseStatus {
  PENDING   // 待审批
  APPROVED  // 已批准
  REJECTED  // 已驳回
  ORDERED   // 已采购
  RECEIVED  // 已入库
}

/// 物品采购申请
model PurchaseRequest {
  id            String         @id @default(cuid())
  requestNo     String         @unique          // 请购单号
  applicant     String                          // 申请人
  itemName      String                          // 物资型号
  quantity      Int                             // 数量
  link          String?                         // 购买链接
  estimatedCost Float                           // 预估总金额
  category      ItemCategory   @default(JIG)     // 物资分类
  status        PurchaseStatus @default(PENDING)
  remark        String?                         // 驳回理由或备注
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([createdAt])
}

/// 全厂物资总仓（按型号汇总）
model JigBaseInventory {
  id          String       @id @default(cuid())
  modelCode   String       @unique // 物资型号，唯一累加基准
  matingModel String?              // 对插型号（仅治具有）
  quantity    Int          @default(0) // 数量
  category    ItemCategory @default(JIG) // 物资分类
  remarks     String?              // 备注
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([category])
}

/// 全局系统配置
model SystemSetting {
  key   String @id
  value String
}

/// 3D打印模具库
model ThreeDMold {
  id           String   @id @default(cuid())
  name         String
  productModel String
  printParams  String?
  scadCode     String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
}
